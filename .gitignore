# Root-level .gitignore for BookingPlatform solution

# ----- Build outputs -----
bin/
obj/
**/bin/
**/obj/
publish/

# ----- Generated assemblies / symbols -----
*.dll
*.exe
*.pdb
*.mdb
*.appx
*.msi
*.nupkg

# ----- NuGet / packages -----
packages/
artifacts/
project.lock.json
project.fragment.lock.json

# ----- IDE / editor -----
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.iml
*.userprefs
*.local

# Rider / JetBrains
/.idea/
*.sln.iml

# ----- ASP.NET / scaffolding -----
ScaffoldingReadMe.txt

# ----- Entity Framework -----
*.dbmdl

# ----- Test results -----
TestResults/
*.trx
*.coverage
*.coveragexml

# ----- Logs, caches, and coverage -----
logs/
*.log
.cache/
coverage/

# ----- Temporary files -----
*.tmp
*.temp
*_ReSharper*/
*.ReSharper
*.ncrunch*
_nCrunch_*/

# ----- OS -----
.DS_Store

# ----- Database files -----
*.mdf
*.ldf

# ----- Local / secret configuration -----
**/appsettings.Development.json
**/appsettings.Local.json
secrets.json

# ----- Generated build artifacts -----
**/obj/**/AssemblyInfo.*
**/obj/**

# ----- VS Code workspace settings keep list -----
.vscode/*
!.vscode/extensions.json

# ----- Ignored generated files -----
wwwroot/lib/

# End
